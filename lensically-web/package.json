{
  "name": "lensically-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/prepare-next-output.js",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prebuild:cf": "node scripts/prepare-next-output.js",
    "build:cf": "node -e \"try{require('node:fs').rmSync('.next',{recursive:true,force:true})}catch{}\" && node scripts/prepare-next-output.js && NEXT_DISABLE_TURBOPACK=1 opennextjs-cloudflare build --skipNextBuild=false",
    "preview:cf": "npm run build:cf && opennextjs-cloudflare preview",
    "deploy:cf": "npm run build:cf && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.72.0"
  }
}
