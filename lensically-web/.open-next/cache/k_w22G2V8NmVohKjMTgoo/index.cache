{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><!--k_w22G2V8NmVohKjMTgoo--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.dbea232f.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.853070df.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Flensically-logo-white-with-black-bg.png&amp;w=64&amp;q=75 1x, /_next/image?url=%2Flensically-logo-white-with-black-bg.png&amp;w=128&amp;q=75 2x\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/dd0b32f5ab39efa9.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/bb8f42ac442d7a63.js\"/><script src=\"/_next/static/chunks/82abf2d65f5428ae.js\" async=\"\"></script><script src=\"/_next/static/chunks/aee6c7720838f8a2.js\" async=\"\"></script><script src=\"/_next/static/chunks/3b2ed5fb7ad1f280.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-8fa6a74498c6fa50.js\" async=\"\"></script><script src=\"/_next/static/chunks/8cd5fe156f301608.js\" async=\"\"></script><script src=\"/_next/static/chunks/ff1a16fafef87110.js\" async=\"\"></script><script src=\"/_next/static/chunks/d2be314c3ece3fbe.js\" async=\"\"></script><script src=\"/_next/static/chunks/a5956cc9c4efcb0b.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Lensically | Threads Analytics and Workflow Support</title><meta name=\"description\" content=\"Lensically is a public Threads analytics and workflow platform homepage with direct links to privacy and data deletion disclosures.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0b3bf435.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/a6dad97d9634a72d.js\" noModule=\"\"></script></head><body class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-[linear-gradient(180deg,#f8fafc_0%,#ffffff_35%,#eef2ff_100%)] text-slate-950\"><nav class=\"border-b border-slate-200/80 bg-white/85 backdrop-blur\"><div class=\"mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8\"><a class=\"flex items-center gap-3\" href=\"/\"><img alt=\"Lensically logo\" width=\"64\" height=\"64\" decoding=\"async\" data-nimg=\"1\" class=\"h-16 w-16 rounded-md\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Flensically-logo-white-with-black-bg.png&amp;w=64&amp;q=75 1x, /_next/image?url=%2Flensically-logo-white-with-black-bg.png&amp;w=128&amp;q=75 2x\" src=\"/_next/image?url=%2Flensically-logo-white-with-black-bg.png&amp;w=128&amp;q=75\"/><div><span class=\"block text-xl font-semibold tracking-tight\">Lensically</span><span class=\"block text-xs uppercase tracking-[0.2em] text-slate-500\">Threads analytics platform</span></div></a><div class=\"hidden items-center gap-7 md:flex\"><a class=\"text-sm font-medium text-slate-700 hover:text-slate-950\" href=\"#product\">Product</a><a class=\"text-sm font-medium text-slate-700 hover:text-slate-950\" href=\"#compliance\">Compliance</a><a class=\"text-sm font-medium text-slate-700 hover:text-slate-950\" href=\"/privacy\">Privacy</a><a class=\"text-sm font-medium text-slate-700 hover:text-slate-950\" href=\"/terms\">Terms</a><a class=\"text-sm font-medium text-slate-700 hover:text-slate-950\" href=\"/data-deletion\">Data Deletion</a></div><div class=\"hidden items-center gap-3 md:flex\"><a class=\"rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-900 transition hover:bg-slate-50\" href=\"/login\">Log in</a><a class=\"rounded-xl border border-sky-700 bg-sky-700 px-4 py-2 text-sm font-medium text-white transition hover:bg-sky-800\" href=\"/signup\">Sign up</a></div><button type=\"button\" aria-expanded=\"false\" class=\"rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900 md:hidden\">Menu</button></div></nav><main class=\"mx-auto flex w-full max-w-7xl flex-col gap-16 px-4 py-12 sm:px-6 lg:px-8 lg:py-16\"><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><section class=\"grid gap-8 lg:grid-cols-[minmax(0,1.4fr)_minmax(320px,0.8fr)] lg:items-center\"><div class=\"space-y-6\"><p class=\"inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-sky-800\">Public product overview</p><div class=\"space-y-4\"><h1 class=\"max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl\">Lensically helps Threads users analyze profiles, review insights, and manage account-connected workflows.</h1><p class=\"max-w-3xl text-lg leading-8 text-slate-600\">Lensically is a web application for Threads-related analytics and workflow support. Users authenticate with email/password or supported OAuth providers, connect a Threads account, and use product features such as profile insights, keyword research, and account-linked publishing workflows.</p></div><div class=\"flex flex-wrap gap-3\"><a class=\"rounded-xl bg-slate-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-800\" href=\"/signup\">Create account</a><a class=\"rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-medium text-slate-900 transition hover:bg-slate-50\" href=\"/login\">Log in</a></div></div><aside class=\"rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.08)]\"><div class=\"rounded-2xl bg-slate-950 p-5 text-slate-50\"><p class=\"text-xs font-semibold uppercase tracking-[0.22em] text-sky-300\">For provider review</p><h2 class=\"mt-3 text-2xl font-semibold\">Public compliance links</h2><p class=\"mt-3 text-sm leading-6 text-slate-300\">The verified public site includes stable legal and compliance pages covering product terms, privacy practices, and account deletion instructions for unauthenticated visitors.</p><div class=\"mt-5 space-y-3\"><a class=\"flex items-center justify-between rounded-xl border border-slate-700 bg-slate-900 px-4 py-3 text-sm font-medium text-white transition hover:border-sky-400 hover:text-sky-200\" href=\"/privacy\"><span>Privacy Policy</span><span aria-hidden=\"true\">↗</span></a><a class=\"flex items-center justify-between rounded-xl border border-slate-700 bg-slate-900 px-4 py-3 text-sm font-medium text-white transition hover:border-sky-400 hover:text-sky-200\" href=\"/terms\"><span>Terms of Service</span><span aria-hidden=\"true\">↗</span></a><a class=\"flex items-center justify-between rounded-xl border border-slate-700 bg-slate-900 px-4 py-3 text-sm font-medium text-white transition hover:border-sky-400 hover:text-sky-200\" href=\"/data-deletion\"><span>Data Deletion Instructions</span><span aria-hidden=\"true\">↗</span></a></div></div></aside></section><section id=\"product\" class=\"grid gap-6 lg:grid-cols-3\"><article class=\"rounded-[24px] border border-slate-200 bg-white p-6 shadow-[0_14px_40px_rgba(15,23,42,0.05)]\"><p class=\"text-xs font-semibold uppercase tracking-[0.22em] text-slate-400\">Feature</p><h2 class=\"mt-4 text-2xl font-semibold text-slate-950\">Threads profile insights</h2><p class=\"mt-3 text-sm leading-7 text-slate-600\">Connect a Threads account to review profile details, post performance, and audience-facing metrics in one place.</p></article><article class=\"rounded-[24px] border border-slate-200 bg-white p-6 shadow-[0_14px_40px_rgba(15,23,42,0.05)]\"><p class=\"text-xs font-semibold uppercase tracking-[0.22em] text-slate-400\">Feature</p><h2 class=\"mt-4 text-2xl font-semibold text-slate-950\">Keyword and profile discovery</h2><p class=\"mt-3 text-sm leading-7 text-slate-600\">Search Threads data and profile information to support discovery, research, and publishing decisions.</p></article><article class=\"rounded-[24px] border border-slate-200 bg-white p-6 shadow-[0_14px_40px_rgba(15,23,42,0.05)]\"><p class=\"text-xs font-semibold uppercase tracking-[0.22em] text-slate-400\">Feature</p><h2 class=\"mt-4 text-2xl font-semibold text-slate-950\">Publishing and scheduling workflows</h2><p class=\"mt-3 text-sm leading-7 text-slate-600\">Manage content workflows tied to your connected account, including scheduling-related application records.</p></article></section><section id=\"compliance\" class=\"grid gap-6 rounded-[32px] border border-slate-200 bg-white p-8 shadow-[0_18px_50px_rgba(15,23,42,0.06)] lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)]\"><div class=\"space-y-4\"><p class=\"text-xs font-semibold uppercase tracking-[0.22em] text-slate-500\">Privacy and deletion</p><h2 class=\"text-3xl font-semibold tracking-tight text-slate-950\">Public documentation for terms, privacy practices, and self-serve account deletion</h2><p class=\"max-w-3xl text-sm leading-7 text-slate-600\">Lensically publishes public legal and compliance pages on the root domain so users and provider reviewers can understand what the application does, what rules govern its use, what account-linked data it stores, and how deletion works without signing in.</p></div><div class=\"space-y-3 rounded-[24px] bg-slate-50 p-5\"><a class=\"flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-900 transition hover:border-sky-300 hover:bg-sky-50\" href=\"/privacy\"><span>Privacy Policy</span><span aria-hidden=\"true\">Open</span></a><a class=\"flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-900 transition hover:border-sky-300 hover:bg-sky-50\" href=\"/terms\"><span>Terms of Service</span><span aria-hidden=\"true\">Open</span></a><a class=\"flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-900 transition hover:border-sky-300 hover:bg-sky-50\" href=\"/data-deletion\"><span>Data Deletion Instructions</span><span aria-hidden=\"true\">Open</span></a></div></section></main></div><!--$--><!--/$--><script src=\"/_next/static/chunks/bb8f42ac442d7a63.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[83917,[\\\"/_next/static/chunks/8cd5fe156f301608.js\\\"],\\\"AuthProvider\\\"]\\n3:I[39756,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n4:I[37457,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n5:I[58586,[\\\"/_next/static/chunks/8cd5fe156f301608.js\\\",\\\"/_next/static/chunks/a5956cc9c4efcb0b.js\\\"],\\\"default\\\"]\\n6:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"OutletBoundary\\\"]\\n7:\\\"$Sreact.suspense\\\"\\n9:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"ViewportBoundary\\\"]\\nb:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"MetadataBoundary\\\"]\\nd:I[68027,[],\\\"default\\\"]\\n:HL[\\\"/_next/static/chunks/dd0b32f5ab39efa9.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.dbea232f.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.853070df.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\